# 本番サイトのURL（末尾スラッシュなし）
# Vercelのダッシュボード → Settings → Environment Variables で設定してください
SITE_URL=https://your-domain.vercel.app

# お問い合わせフォームURL（Googleフォーム等）
# 設定するとcontactページにボタンが表示される。未設定時は準備中メッセージ。
NEXT_PUBLIC_CONTACT_FORM_URL=https://docs.google.com/forms/d/e/xxxxx/viewform

# Google AdSense Publisher ID（審査用コード設置）
# 設定すると全ページのheadにAdSenseスクリプトが出力される。未設定時は出力なし。
NEXT_PUBLIC_GOOGLE_ADSENSE_CLIENT=ca-pub-xxxxxxxxxxxxxxxx
